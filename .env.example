# Server-side secrets for the serverless functions.
#
# Local dev: copy this file to `.env.local` and fill in the real values.
#            `.env.local` is gitignored and must never be committed.
# Production: set each var in Vercel → Project → Settings → Environment Variables.

# --- api/generate.js ---
# The n8n webhook the serverless proxy forwards uploads to.
WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/your-webhook-id

# --- api/stripe-webhook.js (paywall) ---
# Signing secret of the Stripe webhook endpoint (Dashboard → Developers →
# Webhooks → your endpoint → "Signing secret"). For local testing with the
# Stripe CLI, use the `whsec_…` value that `stripe listen` prints.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Supabase SERVICE ROLE key (Dashboard → Project Settings → API → service_role).
# This bypasses Row Level Security so the webhook can flip profiles.paid. It is
# a SECRET — never ship it to the browser, never commit it.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# The n8n webhook the serverless proxy (api/generate.js) forwards uploads to.
#
# Local dev: copy this file to `.env.local` and fill in the real value.
#            `.env.local` is gitignored and must never be committed.
# Production: set WEBHOOK_URL in Vercel → Project → Settings → Environment Variables.
WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/your-webhook-id
